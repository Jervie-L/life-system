{
  "name": "life-system-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner --host 127.0.0.1 --port 5173",
    "test:backend": "python -m unittest discover -s tests -v",
    "build": "tsc && vite build --configLoader runner",
    "build:pwa": "tsc && vite build --configLoader runner --mode pwa",
    "build:ios": "npm run build -- --mode ios && cap sync ios",
    "open:ios": "cap open ios",
    "build:android": "npm run build:pwa && cap sync android",
    "open:android": "cap open android",
    "preview": "vite preview --configLoader runner --host 127.0.0.1 --port 5173"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4"
  }
}
