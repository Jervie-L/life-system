# Copy this file to .env.ios before building the App Store version.
VITE_PRIVACY_POLICY_URL=https://example.com/privacy

# Optional: configure only when using a remote API.
# Without this value, the iOS App stores data locally in its app sandbox.
# App Transport Security requires an HTTPS endpoint with a valid certificate.
# VITE_API_BASE_URL=https://api.example.com
